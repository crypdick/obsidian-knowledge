{
  "name": "obsidian-knowledge",
  "version": "0.3.0",
  "description": "Skills, hooks, and conventions for maintaining Obsidian knowledge base vaults",
  "author": {
    "name": "Ricardo Decal"
  },
  "license": "MIT",
  "keywords": ["obsidian", "knowledge-base", "vault", "organization"],
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/update-changelog.sh"
          },
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/remind-convos.sh"
          }
        ]
      }
    ]
  }
}
